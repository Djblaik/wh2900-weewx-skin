<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>$Extras.page_title</title>
<meta name="theme-color" content="#000000">
<link rel="stylesheet" href="css/wh2900.css">
<link rel="manifest" href="manifest.json">
<meta http-equiv="refresh" content="$Extras.refresh">
<link href="https://fonts.googleapis.com/css2?family=Roboto&display=swap" rel="stylesheet">
</head>
<body class="$nightClass">
<div class="viewport">
    <div class="screen">
        <div class="console">
            <div class="column1-grid">
                <!-- ===== COLUMN 1 ROW 1 ===== -->
                <div class="panel time">
                    <div class="label uv-light-labels">Last updated:</div>
                    <div class="clock">$current.dateTime.format("%H:%M")</div>
                    <div class="datecol">
                        <div class="day">D-M</div>
                        <div class="date">$current.dateTime.format("%d.%m")</div>
                    </div>
                </div>

                <!-- ===== COLUMN 1 ROW 2: MOON PHASE BAR ===== -->
                <div class="panel moon">
                    <div class="moon-bar">
                        <div class="moon-strip" style="--moon-index: ${moonIndex};">
                            <img src="icons/moon/new-moon.svg" alt="New Moon">
                            <img src="icons/moon/waxing-crescent.svg" alt="Waxing Crescent">
                            <img src="icons/moon/waxing-quarter.svg" alt="First Quarter">
                            <img src="icons/moon/waxing-gibbous.svg" alt="Waxing Gibbous">
                            <img src="icons/moon/full-moon.svg" alt="Full Moon">
                            <img src="icons/moon/waning-gibbous.svg" alt="Waning Gibbous">
                            <img src="icons/moon/waning-quarter.svg" alt="Last Quarter">
                            <img src="icons/moon/waning-crescent.svg" alt="Waning Crescent">
                        </div>
                    </div>
                </div>

                <!-- ===== COLUMN 1 ROW 2 ===== -->
                <div class="panel weather">
                    <div class="weather-left">
                        <img src="icons/${icon}.svg" class="wxicon" alt="weather icon">
                    </div>
                    <div class="pressure-trend">
                        <div class="scale">
                            <span class="preserve-spaces"> ≥5</span>
                            <span class="preserve-spaces"> 4</span>
                            <span class="preserve-spaces"> 3</span>
                            <span class="preserve-spaces"> 2</span>
                            <span class="preserve-spaces"> 1</span>
                            <span class="preserve-spaces"> 0</span>
                            <span>-1</span>
                            <span>-2</span>
                            <span>-3</span>
                            <span>-4</span>
                            <span>≤5</span>
                        </div>
                        <div class="marker arrow" style="--trend:${trendStep}"></div>
                        </div>

                    <div class="weather-right">
                        <div class="pressure right">
                            <div class="label white-label pressure-label">PRESSURE</div>
                            <span class="pressure-value">$barowithtrend</span><span class="unit">hpa</span>
                        </div>
                    </div>
                </div>

                <!-- ===== COLUMN 1 ROW 3 ===== -->
                <div class="c1row3">
                    <div class="panel uv">
                        <div class="label white-label uv-light-labels">UVI</div>
                        <div>
                            <span class="value">$current.UV</span>
                            <span class="unit">$uvlevel</span>
                        </div>
                    </div>

                    <div class="panel light">
                        <div class="label white-label uv-light-labels">LIGHT</div>
                        <div>
                            <span class="value">$current.radiation.formatted</span>
                            <span class="unit">W/m²</span>
                        </div>
                    </div>
                </div>
            </div>
            <div class="column2-grid">
                <!-- ===== COLUMN 2 ROW 1 ===== -->
                <div class="panel indoor">
                    <div class="label orange-label">INDOOR</div>
                    <div class="io-values">
                        <span class="temp orange">$current.inTemp.formatted°c</span>
                        <span class="hum orange">$current.inHumidity</span>
                    </div>
                </div>

                <!-- ===== COLUMN 2 ROW 2 ===== -->
                <div class="panel outdoor">
                    <div class="label white-label">OUTDOOR</div>
                    <div class="io-values">
                        <span class="temp white">$current.outTemp.formatted°c</span>
                        <span class="hum white">$current.outHumidity</span>
                    </div>
                    ##<div class="feels-like white">Feels like: $current.appTemp.formatted°c</div>
                </div>

                <!-- ===== COLUMN 2 ROW 3 ===== -->
                <div class="c2row3">
                    <div class="panel wind">
                        <div class="label green-label wind-label">WIND</div>
                    <!--    <div class="speed green">$current.windSpeed.formatted km/h</div>
                        <div class="gust green">Gust $current.windGust.formatted km/h</div>
                    -->
                        #raw
                        <svg class="dial" viewBox="0 0 200 200">
                            <!-- Outer ring -->
                            <circle cx="100" cy="100" r="90"
                                    fill="none"
                                    stroke="#3a3a3a"
                                    stroke-width="6"/>

                            <!-- Inner ring -->
                            <circle cx="100" cy="100" r="65"
                                    fill="none"
                                    stroke="#2a2a2a"
                                    stroke-width="2"/>

                            <!-- Cardinal labels -->
                            <g fill="#777" font-size="12"
                                text-anchor="middle"
                                dominant-baseline="middle">
                                <text x="100" y="16">N</text>
                                <text x="184" y="100">E</text>
                                <text x="100" y="188">S</text>
                                <text x="16" y="100">W</text>
                            </g>

                            <!-- Direction marker (wind FROM) -->
                        #end raw
                            <g transform="rotate($windArrowAngle 100 100)">
                                <g transform="rotate(180 100 16.67)">
                                    <polygon points="100,6 92,22 108,22" fill="#9cff00"/>
                                </g>
                            </g>
                        #raw
                            <!-- Center value -->
                            <g fill="#9cff00"
                                font-family="monospace"
                                text-anchor="middle">
                        #end raw       
                                <text x="100" y="105" font-size="35">$current.windSpeed.formatted km/h</text>
                                <text x="100" y="130" font-size="17">Gust $current.windGust.formatted km/h</text>
                        #raw        
                            </g>
                        </svg>
                        #end raw
                    </div>    

                    <div class="panel rain">
                        <div class="label blue-label">RAIN</div>
                        <div class="raindata">
                            <div class="blue rainline"><span>Rain Rate: </span></div>
                            <div class="blue rainline"><span>$current.rainRate.formatted mm/hr</span></div>
                            <div class="blue rainline"><span>From 12 am: </span></div>
                            <div class="blue rainline"><span>$day.rain.sum</span></div>
                            <div class="blue rainline"><span>From 9 am: </span></div>
                            <div class="blue rainline"><span>$since($hour=9).rain.sum</span></div>
                            <div class="blue rainline"><span>To 9 am $label_date :</span></div>
                            <div class="blue rainline"><span>$rainto</span></div>
                            <div class="blue rainline"><span>Last rain: </span></div>
                            <div class="blue rainline"><span>$lastrain</span></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
</body>
<script>
    if("serviceWorker" in navigator){
    navigator.serviceWorker.register("sw.js");
    }
</script>
</html> 